<script>
  function toggle(card) { card.classList.toggle('open'); }
  function toggleAll(id) {
    const group = document.getElementById(id);
    if (!group) return;
    const items = [...group.querySelectorAll('.acc-item')];
    const anyOpen = items.some(i => i.classList.contains('open'));
    items.forEach(i => anyOpen ? i.classList.remove('open') : i.classList.add('open'));
  }
</script>
