    {
      "id": "b2c3d4e5-0002-0002-0002-000000000007",
      "name": "Preparar Email Noticias",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [940, 260],
      "parameters": {
        "jsCode": "const newsData = $input.first().json;\nconst results = newsData.news_results || newsData.organic_results || [];\nconst date = $('Calcular Semana del Ciclo').first().json.date;\n\nlet newsItems = '';\nresults.slice(0, 5).forEach((item, i) => {\n  newsItems += `<li><strong>${item.title || item.snippet || 'Noticia ' + (i+1)}</strong><br>`;\n  if (item.link) newsItems += `<a href=\"${item.link}\">Leer más</a>`;\n  newsItems += '</li>';\n});\n\nif (!newsItems) {\n  newsItems = '<li>Consulta las últimas noticias del sector en nuestro blog.</li>';\n}\n\nreturn [{\n  json: {\n    subject: `📰 Noticias de la industria - Semana del ${date}`,\n    body: `<h2>Noticias de la Industria Esta Semana</h2><p>Estimado/a,</p><p>Te traemos las noticias más relevantes del sector esta semana:</p><ul>${newsItems}</ul><p>Mantente actualizado y sigue creciendo profesionalmente.</p><p>Saludos,<br>El Equipo</p>`,\n    weekType: 'noticias'\n  }\n}];"
      }
    },
