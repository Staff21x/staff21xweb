    },
    {
      "parameters": {
        "jsCode": "const empresa = $json['Empresa_Nombre'] || '';\n\nreturn [{\n  json: {\n    Empresa_Rut: $json['Empresa_Rut'] || '',\n    Empresa_Nombre: empresa,\n    apolloBody: JSON.stringify({\n      per_page: 10,\n      organization_names: [empresa],\n      person_titles: [\n        'Jefe de Capacitación',\n        'Gerente RRHH',\n        'Subgerente de Personas',\n        'Gerente Desarrollo Organizacional',\n        'Gerente Formación',\n        'HR Manager',\n        'Training Manager',\n        'People Manager',\n        'Learning and Development Manager'\n      ]\n    })\n  }\n}];"
      },
      "id": "1a2b3c4d-0005",
      "name": "Preparar Solicitud Apollo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 460]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/api/v1/mixed_people/search",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.apolloBody }}",
        "options": {}
      },
      "id": "1a2b3c4d-0006",
      "name": "Buscar en Apollo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1260, 460],
      "credentials": {
        "httpHeaderAuth": {
          "id": "APOLLO_CRED_ID",
          "name": "Apollo X-Api-Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const apolloData = $input.first().json;\nconst company = $('Preparar Solicitud Apollo').first().json;\n\nconst people = (apolloData.people || []).filter(function(p) {\n  const email = p.email || '';\n  return email.includes('@') && !email.startsWith('email_not_unlocked');\n});\n\nconst stats = $workflow.staticData;\nstats.processedCount = (stats.processedCount || 0) + 1;\nstats.contactsFound = (stats.contactsFound || 0) + people.length;\n\nconst updateData = { Empresa_Rut: company.Empresa_Rut };\n\nfor (let i = 1; i <= 15; i++) {\n  const person = people[i - 1];\n  let label = '';\n  let email = '';\n  if (person) {\n    const firstName = person.first_name || '';\n    const lastName = person.last_name || '';\n    const fullName = [firstName, lastName].filter(function(s) { return s.length > 0; }).join(' ');\n    const title = person.title || '';\n    label = title ? (fullName + ' | ' + title) : fullName;\n    email = person.email || '';\n  }\n  if (i === 1) {\n    updateData['CONTACTO'] = label;\n    updateData['CORREO'] = email;\n  } else {\n    updateData['CONTACTO_' + i] = label;\n    updateData['CORREO_' + i] = email;\n  }\n}\n\nreturn [{ json: updateData }];"
      },
