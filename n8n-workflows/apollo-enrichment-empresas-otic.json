    {
      "parameters": {
        "jsCode": "const stats = $workflow.staticData;\nconst processed = stats.processedCount || 0;\nconst found = stats.contactsFound || 0;\n\nstats.processedCount = 0;\nstats.contactsFound = 0;\n\nreturn [{\n  json: {\n    estado: 'Enriquecimiento completado',\n    empresasEnriquecidas: processed,\n    contactosEncontrados: found,\n    promedioPorEmpresa: processed > 0 ? (found / processed).toFixed(1) : '0.0',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
