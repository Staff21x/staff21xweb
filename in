<!DOCTYPE html>

<html lang="es">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Staff21x — Trabajadores Digitales con Resultados Humanos</title>

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>

*{box-sizing:border-box;margin:0;padding:0}

html{scroll-behavior:smooth}

:root{

  --bg:#080a10;

  --bg1:#0d1017;

  --bg2:#131720;

  --bg3:#1a1f2e;

  --border:#1e2438;

  --border2:#2a3050;

  --text:#d8ddf0;

  --text2:#7a82a0;

  --text3:#3a4060;

  --accent:#5b6af0;

  --accent2:#7c3aed;

  --grad:linear-gradient(135deg,#5b6af0,#7c3aed);

  --grad-dim:rgba(91,106,240,.10);

  --grad-border:rgba(91,106,240,.25);

  --r:12px;

}

body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6;overflow-x:hidden}

.mono{font-family:'JetBrains Mono',monospace}



  .otec-banner h2 {

    font-size: 28px;

    background: var(--grad);

    -webkit-background-clip: text;

    -webkit-text-fill-color: transparent;

    font-weight: 800;

}

.otec-banner p {

    font-size: 18px;

    opacity: 0.8;

}



/* ── SCROLL REVEAL ── */

.reveal{opacity:1;transform:none}

.reveal.visible{opacity:1;transform:none}

.reveal-delay-1{}

.reveal-delay-2{}

.reveal-delay-3{}

.reveal-delay-4{}



/* HERO — always visible, animates in on load */

.hero-anim{opacity:0;transform:translateY(20px);animation:heroIn .7s cubic-bezier(.16,1,.3,1) forwards}

@keyframes heroIn{to{opacity:1;transform:none}}

.hero-anim-1{animation-delay:.1s}

.hero-anim-2{animation-delay:.25s}

.hero-anim-3{animation-delay:.4s}

.hero-anim-4{animation-delay:.55s}

.hero-anim-5{animation-delay:.7s}



/* word-by-word headline reveal */

.word-reveal .word{display:inline-block;opacity:1;transform:none}

.word-reveal.visible .word{opacity:1;transform:none}



/* ── NAV ── */

nav{position:fixed;top:0;left:0;right:0;z-index:100;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 48px;background:rgba(8,10,16,.85);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}

.logo{font-family:'Inter',sans-serif;font-size:18px;font-weight:800;color:#fff;text-decoration:none;letter-spacing:-1px}

.logo span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.nav-links{display:flex;gap:32px;list-style:none}

.nav-links a{font-size:13px;font-weight:500;color:var(--text2);text-decoration:none;transition:color .15s}

.nav-links a:hover{color:var(--text)}

.nav-right{display:flex;gap:8px;align-items:center}

.btn-nav-ghost{padding:8px 18px;border-radius:8px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-size:13px;font-weight:500;text-decoration:none;transition:all .15s;font-family:'Inter',sans-serif}

.btn-nav-ghost:hover{border-color:var(--accent);color:var(--accent)}

.btn-nav-cta{padding:8px 20px;border-radius:8px;background:var(--grad);color:#fff;font-size:13px;font-weight:600;text-decoration:none;transition:all .2s;box-shadow:0 0 20px rgba(91,106,240,.3)}

.btn-nav-cta:hover{box-shadow:0 0 32px rgba(91,106,240,.5);transform:translateY(-1px)}



/* ── HERO ── */

.hero{min-height:100vh;display:flex;align-items:center;padding:80px 48px 60px;max-width:1280px;margin:0 auto;gap:64px}

.hero-left{flex:1;min-width:0}

.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--grad-dim);border:1px solid var(--grad-border);border-radius:999px;padding:5px 14px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:.3px;margin-bottom:28px}

.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:bdot 2s infinite}

@keyframes bdot{0%,100%{opacity:1;box-shadow:0 0 0 rgba(91,106,240,.5)}50%{opacity:.5;box-shadow:0 0 8px rgba(91,106,240,.8)}}

h1{font-size:clamp(42px,5.5vw,70px);font-weight:900;line-height:1.04;letter-spacing:-3px;color:#fff;margin-bottom:22px}

h1 .grad{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.hero-sub{font-size:17px;color:var(--text2);line-height:1.7;font-weight:400;max-width:480px;margin-bottom:36px}

.hero-sub strong{color:var(--text);font-weight:600}

.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:52px}

.btn-primary{padding:14px 30px;border-radius:10px;background:var(--grad);color:#fff;font-size:15px;font-weight:600;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 24px rgba(91,106,240,.35)}

.btn-primary:hover{box-shadow:0 4px 36px rgba(91,106,240,.55);transform:translateY(-2px)}

.btn-outline{padding:14px 30px;border-radius:10px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-size:15px;font-weight:500;text-decoration:none;transition:all .2s}

.btn-outline:hover{border-color:var(--accent);color:var(--text)}

.hero-numbers{display:flex;gap:40px}

.hn-item{}

.hn-num{font-size:32px;font-weight:800;color:#fff;letter-spacing:-1.5px;line-height:1}

.hn-num span{font-size:20px;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.hn-label{font-size:12px;color:var(--text2);margin-top:4px}



/* ── TERMINAL ── */

.hero-right{width:500px;flex-shrink:0}

.terminal{background:var(--bg1);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:0 32px 96px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.03)}

.term-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:13px 18px;display:flex;align-items:center;gap:7px}

.tdot{width:11px;height:11px;border-radius:50%}

.term-title{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);margin-left:10px;letter-spacing:.3px}

.term-body{padding:22px 20px;display:flex;flex-direction:column;gap:4px}

.tl{font-family:'JetBrains Mono',monospace;font-size:12.5px;line-height:1.7}

.tp{color:var(--accent)}

.tc{color:var(--text)}

.to{color:var(--text2);padding-left:18px}

.to.ok{color:#22d3ee}

.to.vi{color:#a78bfa}

.to.wa{color:#fbbf24}

.tdiv{height:1px;background:var(--border);margin:8px 0}

.tcur{display:inline-block;width:7px;height:13px;background:var(--accent);animation:cur .9s infinite;vertical-align:middle;margin-left:2px}

@keyframes cur{0%,100%{opacity:1}50%{opacity:0}}



/* ── MARQUEE ── */

.marquee-section{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:0;overflow:hidden;position:relative;background:var(--bg1)}

.marquee-section::before,.marquee-section::after{content:'';position:absolute;top:0;bottom:0;width:160px;z-index:2;pointer-events:none}

.marquee-section::before{left:0;background:linear-gradient(90deg,var(--bg1),transparent)}

.marquee-section::after{right:0;background:linear-gradient(270deg,var(--bg1),transparent)}

.marquee-track{display:flex;gap:0}

.marquee-row{display:flex;gap:10px;padding:16px 0;white-space:nowrap;animation:scroll-left 30s linear infinite}

.marquee-row.reverse{animation:scroll-right 30s linear infinite}

@keyframes scroll-left{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

@keyframes scroll-right{0%{transform:translateX(-50%)}100%{transform:translateX(0)}}

.mpill{display:inline-flex;align-items:center;gap:7px;background:var(--bg2);border:1px solid var(--border);border-radius:999px;padding:8px 16px;font-size:13px;color:var(--text2);white-space:nowrap;flex-shrink:0}

.mpill-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;opacity:.7}



/* ── SECTION ── */

.wrap{max-width:1280px;margin:0 auto;padding:100px 48px}

.eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:14px;display:block}

h2{font-size:clamp(30px,4vw,48px);font-weight:800;letter-spacing:-2px;line-height:1.1;color:#fff;margin-bottom:16px}

.sec-sub{font-size:16px;color:var(--text2);max-width:520px;line-height:1.7;font-weight:400;margin-bottom:56px}



/* ── ROLES ── */

.roles-bg{background:var(--bg1)}

.roles-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;background:var(--border)}

.rc{background:var(--bg1);padding:38px;transition:background .2s}

.rc:hover{background:var(--bg2)}

.rc-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);letter-spacing:1px;margin-bottom:14px}

.rc-name{font-size:22px;font-weight:800;color:#fff;letter-spacing:-1px;margin-bottom:5px}

.rc-tag{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);margin-bottom:14px;display:block}

.rc-desc{font-size:14px;color:var(--text2);line-height:1.65;margin-bottom:22px;font-weight:400}

.code-block{background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:16px;margin-bottom:20px;overflow:hidden}

.code-header{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:7px}

.code-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);opacity:.7}

.code-block pre{font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.75;color:var(--text2);white-space:pre-wrap;overflow:hidden}

pre .kw{color:#c084fc}

pre .fn{color:#60a5fa}

pre .str{color:#86efac}

pre .cm{color:var(--text3)}

pre .num{color:#fb923c}

.rc-feats{list-style:none;display:flex;flex-direction:column;gap:8px}

.rc-feats li{display:flex;align-items:flex-start;gap:9px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text2)}

.rc-feats li::before{content:"→";color:var(--accent);flex-shrink:0}



<section class="otec-banner" style="margin: 60px 0;">

  <div class="wrap" style="background: rgba(91, 106, 240, 0.1); border: 2px dashed var(--grad); border-radius: 20px; padding: 40px; text-align: center;">

    <span class="eyebrow" style="color: var(--grad);">¿Eres una OTEC?</span>

    <h2 style="margin: 15px 0;">Tenemos un Trabajador Digital especialista para tu industria</h2>

    <p>Automatiza cotizaciones SENCE, gestión de alumnos y seguimiento comercial 24/7.</p>

    <a href="otec.html" class="bsub" style="display: inline-block; width: auto; margin-top: 20px; padding: 15px 40px; text-decoration: none;">

      Ver solución para OTECs

    </a>

  </div>

</section>



  



  

/* ── HOW ── */

.how-grid{display:grid;grid-template-columns:repeat(5,1fr);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}

.hs{padding:30px 22px;border-right:1px solid var(--border);transition:background .2s}

.hs:last-child{border-right:none}

.hs:hover{background:var(--bg2)}

.hs-n{font-family:'JetBrains Mono',monospace;font-size:28px;font-weight:500;color:var(--border2);line-height:1;margin-bottom:16px}

.hs h4{font-size:13px;font-weight:700;color:#fff;margin-bottom:8px;letter-spacing:-.3px}

.hs p{font-size:12px;color:var(--text2);line-height:1.65}



/* ── CTA BAND ── */

.cta-band{background:linear-gradient(135deg,rgba(91,106,240,.12),rgba(124,58,237,.12));border-top:1px solid rgba(91,106,240,.2);border-bottom:1px solid rgba(91,106,240,.2);padding:64px 48px;text-align:center}

.cta-band-inner{max-width:640px;margin:0 auto}

.cta-band h3{font-size:34px;font-weight:800;color:#fff;letter-spacing:-1.5px;margin-bottom:10px}

.cta-band p{font-size:16px;color:var(--text2);margin-bottom:28px}

.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}



/* ── PRICING ── */

.pricing-bg{background:var(--bg1)}

.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;align-items:start}

.pc{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:28px;position:relative;transition:border-color .2s,transform .2s}

.pc:hover{border-color:var(--border2);transform:translateY(-2px)}

.pc.feat{background:linear-gradient(160deg,#1a1f45 0%,#0f1128 100%);border:1px solid rgba(91,106,240,.4);box-shadow:0 0 60px rgba(91,106,240,.1);transform:scale(1.03)}

.pc.feat:hover{transform:scale(1.03) translateY(-2px)}

.pc-top-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--grad);color:#fff;font-size:11px;font-weight:700;padding:4px 16px;border-radius:999px;white-space:nowrap;letter-spacing:.3px}

.pc-icon-row{display:flex;align-items:center;gap:14px;margin-bottom:20px}

.pc-icon{width:44px;height:44px;border-radius:12px;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:20px}

.feat .pc-icon{background:rgba(91,106,240,.15);border-color:rgba(91,106,240,.3)}

.pc-plan-name{font-size:20px;font-weight:800;color:#fff;letter-spacing:-.5px}

.pc-plan-sub{font-size:12px;color:var(--text2);margin-top:2px}

.pc-price-row{margin-bottom:6px}

.pc-price{font-size:42px;font-weight:900;color:#fff;letter-spacing:-2px;line-height:1}

.feat .pc-price{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.pc-price sup{font-size:18px;font-weight:700;letter-spacing:0;vertical-align:super}

.pc-price sub{font-size:14px;font-weight:400;color:var(--text2);letter-spacing:0;vertical-align:baseline;-webkit-text-fill-color:var(--text2)}

.pc-tagline{font-size:13px;color:var(--text2);margin-bottom:22px}

.pc-line{height:1px;background:var(--border);margin-bottom:20px}

.pc-feats{list-style:none;display:flex;flex-direction:column;gap:9px;margin-bottom:24px}

.pc-feats li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--text2)}

.pck{color:var(--accent);font-size:14px;flex-shrink:0;font-weight:700;margin-top:1px}

.pck-icon{width:16px;height:16px;border-radius:50%;background:rgba(91,106,240,.15);border:1px solid rgba(91,106,240,.3);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;font-size:9px}

.feat .pck-icon{background:rgba(91,106,240,.25)}

.px{color:var(--text3);font-size:14px;flex-shrink:0}

.bp{display:block;text-align:center;padding:13px 20px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;transition:all .2s;font-family:'Inter',sans-serif}

.bp-out{border:1px solid var(--border2);color:var(--text2);background:transparent}

.bp-out:hover{border-color:var(--accent);color:var(--accent)}

.bp-grad{background:var(--grad);color:#fff;box-shadow:0 4px 20px rgba(91,106,240,.3)}

.bp-grad:hover{box-shadow:0 4px 30px rgba(91,106,240,.5);transform:translateY(-1px)}

.pc-foot{font-size:12px;color:var(--text2);text-align:center;margin-top:14px;line-height:1.5}

.pricing-note{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);margin-top:24px}



/* ── FAQ ── */

.faq-list{max-width:720px;display:flex;flex-direction:column}

.fi{border-bottom:1px solid var(--border)}

.fb{width:100%;padding:20px 0;display:flex;justify-content:space-between;align-items:center;background:none;border:none;cursor:pointer;color:var(--text);font-family:'Inter',sans-serif;font-size:15px;font-weight:500;text-align:left;gap:16px;transition:color .15s}

.fb:hover{color:var(--accent)}

.fi-icon{font-size:20px;flex-shrink:0;color:var(--text3);transition:transform .3s}

.fa{font-size:14px;color:var(--text2);line-height:1.75;max-height:0;overflow:hidden;transition:max-height .35s ease,padding .3s}

.fi.open .fa{max-height:280px;padding-bottom:20px}

.fi.open .fi-icon{transform:rotate(45deg);color:var(--accent)}



/* ── CONTACT ── */

.contact-bg{background:var(--bg1)}

.cg{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}

.ci p{font-size:16px;color:var(--text2);line-height:1.7;margin-bottom:28px}

.clinks{display:flex;flex-direction:column;gap:8px}

.cl{display:flex;align-items:center;gap:12px;text-decoration:none;padding:14px 16px;border:1px solid var(--border);border-radius:10px;background:var(--bg2);transition:border-color .2s}

.cl:hover{border-color:var(--grad-border)}

.cl-icon{width:36px;height:36px;border-radius:9px;background:var(--grad-dim);border:1px solid var(--grad-border);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}

.cl-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text);display:block;margin-bottom:2px;text-transform:uppercase;letter-spacing:.5px}

.cl-val{font-size:13px;color:var(--text);font-weight:600}



.cform{display:flex;flex-direction:column;gap:12px}

.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px}

.fg{display:flex;flex-direction:column;gap:5px}

.fg label{font-family:'JetBrains Mono',monospace;font-size:11px;color:#fff;text-transform:uppercase;letter-spacing:.8px;font-weight:600}

.fg input,.fg select,.fg textarea{background:var(--bg2);border:1px solid var(--border2);border-radius:9px;padding:12px 14px;color:#fff;font-family:'Inter',sans-serif;font-size:14px;outline:none;transition:all .2s}

.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent);background:var(--bg3);box-shadow:0 0 0 3px rgba(91,106,240,.15)}

.fg input::placeholder,.fg textarea::placeholder{color:var(--text2)}

.fg select{appearance:none;cursor:pointer;color:#fff}

.fg textarea{resize:vertical;min-height:90px}



  .bsub {

  background: var(--grad);

  color: #fff;

  border: none;

  padding: 16px;

  border-radius: 10px;

  font-family: 'Inter', sans-serif;

  font-size: 15px;

  font-weight: 800;

  text-transform: uppercase;

  letter-spacing: 1px;

  cursor: pointer;

  width: 100%;

  margin-top: 10px;

  transition: all 0.3s ease;

  box-shadow: 0 10px 25px rgba(91, 106, 240, 0.3);

}

.bsub:hover {

  transform: translateY(-2px);

  filter: brightness(1.1);

  box-shadow: 0 15px 30px rgba(91, 106, 240, 0.5);

}



  /* --- ESTILO DEL BOTÓN AGENDAR --- */

.bsub {

  background: var(--grad);

  color: #fff;

  border: none;

  padding: 16px;

  border-radius: 10px;

  font-family: 'Inter', sans-serif;

  font-size: 15px;

  font-weight: 800;

  text-transform: uppercase;

  letter-spacing: 1px;

  cursor: pointer;

  width: 100%;

  margin-top: 10px;

  transition: all 0.3s ease;

  box-shadow: 0 10px 25px rgba(91, 106, 240, 0.3);

}



.bsub:hover {

  transform: translateY(-2px);

  box-shadow: 0 15px 30px rgba(91, 106, 240, 0.5);

  filter: brightness(1.1);

}



.bsub:disabled {

  background: #22c55e !important;

  cursor: not-allowed;

  transform: none;

}



/* ── FOOTER ── */

footer{border-top:1px solid var(--border);padding:60px 48px 32px;max-width:1280px;margin:0 auto}

.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:48px}

.f-brand-sub{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);line-height:1.8;max-width:200px;margin-top:12px}

.fc h5{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:14px}

.fc ul{list-style:none;display:flex;flex-direction:column;gap:9px}

.fc ul a{font-size:13px;color:var(--text2);text-decoration:none;transition:color .15s}

.fc ul a:hover{color:var(--accent)}

.fbot{border-top:1px solid var(--border);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}

.fbot p{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3)}

.fbl{display:flex;gap:20px}

.fbl a{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);text-decoration:none}

.fbl a:hover{color:var(--text2)}



/* ── WSP ── */

.wsp-btn{position:fixed;bottom:24px;right:24px;z-index:99;width:52px;height:52px;border-radius:50%;background:#25d366;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.4);text-decoration:none;transition:transform .2s,box-shadow .2s}

.wsp-btn:hover{transform:scale(1.1);box-shadow:0 4px 30px rgba(37,211,102,.6)}



/* ── RESPONSIVE ── */

@media(max-width:1024px){

  nav{padding:0 24px}

  .nav-links{display:none}

