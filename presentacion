    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const currentSlideDisplay = document.getElementById('current-slide');

        function updateSlide(newSlide) {
            if (newSlide < 0 || newSlide >= totalSlides) return;
            
            slides[currentSlide].classList.remove('active');
            slides[currentSlide].classList.add('prev');
            
            currentSlide = newSlide;
            
            slides[currentSlide].classList.add('active');
            slides[currentSlide].classList.remove('prev');
            
            prevBtn.disabled = currentSlide === 0;
            nextBtn.disabled = currentSlide === totalSlides - 1;
            currentSlideDisplay.textContent = currentSlide + 1;
            
            animateSlideElements();
        }

        function animateSlideElements() {
            const slide = slides[currentSlide];
            
            if (currentSlide === 1) {
                const cards = slide.querySelectorAll('.advantage-card');
                cards.forEach((card, index) => {
                    setTimeout(() => {
                        card.style.animation = 'slideInLeft 0.6s ease-out forwards';
                    }, index * 100);
                });
            }
            
            if (currentSlide === 2) {
                const steps = slide.querySelectorAll('.step');
                steps.forEach((step, index) => {
                    setTimeout(() => {
                        step.style.animation = 'slideInRight 0.6s ease-out forwards';
                    }, index * 100);
                });
            }
            
            if (currentSlide === 3) {
                const useCases = slide.querySelectorAll('.use-case');
                useCases.forEach((useCase, index) => {
                    setTimeout(() => {
                        useCase.style.animation = 'slideInLeft 0.6s ease-out forwards';
                    }, index * 80);
                });
            }
            
            if (currentSlide === 5) {
                const items = slide.querySelectorAll('.checklist li');
                items.forEach((item, index) => {
                    setTimeout(() => {
                        item.style.animation = 'fadeIn 0.6s ease-out forwards';
                    }, index * 150);
                });
            }
            
            if (currentSlide === 7) {
                const tools = slide.querySelectorAll('.tool');
                tools.forEach((tool, index) => {
                    setTimeout(() => {
                        tool.style.animation = 'scaleIn 0.5s ease-out forwards';
                    }, index * 100);
                });
            }
            
            if (currentSlide === 8) {
                const diffCards = slide.querySelectorAll('.diff-card');
                diffCards.forEach((card, index) => {
                    setTimeout(() => {
                        card.style.animation = 'slideInRight 0.6s ease-out forwards';
                    }, index * 100);
                });
            }
            
            if (currentSlide === 9) {
                const items = slide.querySelectorAll('.checklist li');
                items.forEach((item, index) => {
                    setTimeout(() => {
                        item.style.animation = 'fadeIn 0.6s ease-out forwards';
                    }, index * 100);
                });
            }
        }

        prevBtn.addEventListener('click', () => updateSlide(currentSlide - 1));
        nextBtn.addEventListener('click', () => updateSlide(currentSlide + 1));

        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') updateSlide(currentSlide - 1);
            if (e.key === 'ArrowRight') updateSlide(currentSlide + 1);
        });

        window.addEventListener('load', () => {
            animateSlideElements();
        });
    </script>
